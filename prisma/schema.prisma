generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agent {
  id            String   @id @default(cuid())
  wallet        String   @unique
  pda           String   @unique
  owner         String
  metadataUri   String
  registeredAt  DateTime
  isVerified    Boolean  @default(false)
  verifiedAt    DateTime?
  sponsored     Boolean  @default(false)  // Was registration sponsored (free)?
  
  // Extended metadata (cached from AgentCard)
  name          String?
  description   String?
  twitter       String?
  website       String?
  image         String?  // Avatar/profile picture URL
  
  // Service endpoints
  mcpEndpoint   String?
  a2aEndpoint   String?
  x402Wallet    String?
  serviceTypes  String[]  @default([])
  skills        String[]  @default([])
  
  // Layer 2 verification (endpoint challenge-response)
  layer2Verified      Boolean  @default(false)
  layer2VerifiedAt    DateTime?
  verifiedEndpointUrl String?
  l2AttestationMethod String?
  registrationSource  String?
  activityCount       Int      @default(0)
  lastActiveAt        DateTime?

  // Passport (soulbound NFT)
  passportMint        String?
  passportMintedAt    DateTime?
  passportTxHash      String?

  // Reputation
  reputationScore Float   @default(0)
  feedbackCount   Int     @default(0)
  
  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastSyncedAt  DateTime @default(now())
  
  // Relations
  feedbackReceived Feedback[] @relation("FeedbackReceived")
  feedbackGiven    Feedback[] @relation("FeedbackGiven")
  attestationsReceived Attestation[] @relation("AttestationsReceived")
  attestationsGiven    Attestation[] @relation("AttestationsGiven")
  createdByUsers   UserAgent[]
  capabilities     Capability[]
  trustScore       AgentScore?
  
  // Delegated Signing Authority
  agentWallets     AgentWallet[]
  transactionRequests TransactionRequest[]
  apiKeys          ApiKey[]
  transactionPolicy TransactionPolicy?

  // Partner platform (SeekerClaw, etc.)
  platformId       String?          // null for self-hosted/organic agents
  nftAddress       String?          // Metaplex Core asset address

  @@index([name])
  @@index([reputationScore])
  @@index([isVerified])
  @@index([platformId])
}

model Feedback {
  id          String   @id @default(cuid())
  
  // Who gave feedback
  fromWallet  String
  fromAgent   Agent?   @relation("FeedbackGiven", fields: [fromWallet], references: [wallet])
  
  // Who received feedback
  toWallet    String
  toAgent     Agent    @relation("FeedbackReceived", fields: [toWallet], references: [wallet])
  
  // Feedback content
  score       Int      // 0-100
  comment     String?
  weight      Float    @default(1.0)  // Verified agents = 2.0, others = 1.0
  
  // Verification
  signature   String   // Wallet signature proving authenticity
  fromIsVerified Boolean @default(false) // Was giver verified at time of feedback?
  txHash      String?  // On-chain hash if stored on-chain
  
  createdAt   DateTime @default(now())

  @@unique([fromWallet, toWallet])
  @@index([toWallet])
  @@index([score])
}

model SyncState {
  id          String   @id @default("main")
  lastSlot    BigInt   @default(0)
  lastSyncAt  DateTime @default(now())
}

model AgentCard {
  id          String   @id @default(cuid())
  wallet      String   @unique
  cardJson    String   // JSON blob of the agent card
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([wallet])
}

model Attestation {
  id              String    @id @default(cuid())
  
  // Who is attesting
  attesterWallet  String
  attester        Agent     @relation("AttestationsGiven", fields: [attesterWallet], references: [wallet])
  
  // Who is being attested
  subjectWallet   String
  subject         Agent     @relation("AttestationsReceived", fields: [subjectWallet], references: [wallet])
  
  // Attestation details
  type            String    @default("trust")  // trust, endorsement, interaction, skill
  confidence      Int       @default(50)       // 1-100
  context         String?                      // Optional note/reason
  skill           String?                      // For skill attestations: which skill
  
  // Verification
  signature       String?                      // Wallet signature (optional for trusted sources)
  txHash          String?                      // On-chain anchor (future)
  
  // Lifecycle
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  revokedAt       DateTime?
  
  @@unique([attesterWallet, subjectWallet, type])
  @@index([subjectWallet])
  @@index([attesterWallet])
  @@index([type])
}

model User {
  id              String    @id @default(cuid())
  
  // Login methods (one of these is set)
  privyId         String?   @unique
  walletAddress   String?   @unique
  email           String?   @unique
  emailVerified   Boolean   @default(false)
  
  // Profile
  displayName     String?
  username        String?   @unique
  avatarUrl       String?   @db.Text
  
  // Session management
  sessionToken    String?   @unique
  sessionExpiry   DateTime?
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastLoginAt     DateTime  @default(now())
  
  // Relations
  agents          UserAgent[]
  
  @@index([privyId])
  @@index([walletAddress])
  @@index([email])
  @@index([sessionToken])
}

model UserAgent {
  id              String    @id @default(cuid())
  
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  agentWallet     String
  agent           Agent     @relation(fields: [agentWallet], references: [wallet], onDelete: Cascade)
  
  createdAt       DateTime  @default(now())
  
  @@unique([userId, agentWallet])
  @@index([userId])
  @@index([agentWallet])
}

model GrantApplication {
  id               String   @id @default(cuid())
  agentName        String
  walletAddress    String
  twitter          String?
  website          String?
  description      String
  useCase          String
  fundingAmount    String
  fundingDuration  String
  milestones       String
  teamBackground   String?
  status           String   @default("pending")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([walletAddress])
  @@index([status])
}

model AgentChallenge {
  id          String   @id @default(cuid())
  wallet      String
  nonce       String   @unique
  endpointUrl String
  createdAt   DateTime @default(now())
  expiresAt   DateTime
  verified    Boolean  @default(false)
  verifiedAt  DateTime?

  @@index([wallet])
  @@index([nonce])
}

model EmailOTP {
  id              String    @id @default(cuid())
  email           String
  code            String
  expiresAt       DateTime
  verified        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  
  @@index([email])
  @@index([code])
}

model WebhookConfig {
  id              String    @id @default(cuid())
  platform        String    // e.g., "spawnr"
  url             String
  events          String[]  // e.g., ["reputation_change", "verification_complete"]
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([platform])
}

model Capability {
  id          String   @id @default(cuid())
  wallet      String
  capability  String
  endpoint    String
  description String?
  pricing     Json?
  chain       String   @default("solana")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  active      Boolean  @default(true)

  agent       Agent    @relation(fields: [wallet], references: [wallet])

  @@unique([wallet, capability])
  @@index([capability])
  @@index([chain])
}

model CrossChainWebhook {
  id        String   @id @default(cuid())
  chain     String
  address   String
  url       String
  secret    String?  // HMAC-SHA256 signing key
  createdAt DateTime @default(now())

  @@unique([chain, address])
  @@index([chain, address])
}

model A2AMessage {
  id          String   @id @default(cuid())
  
  // Routing
  fromWallet  String
  toWallet    String
  
  // Content
  message     String   @db.Text
  context     String?  @db.Text  // JSON
  
  // Task tracking
  taskId      String?  @unique
  status      String   @default("created")  // created, working, complete, failed
  progress    Int      @default(0)
  result      String?  @db.Text  // JSON
  
  // Verification
  fromVerified Boolean @default(false)
  signature   String?
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([toWallet])
  @@index([fromWallet])
  @@index([status])
  @@index([createdAt])
}

model AgentScore {
  id              String    @id @default(cuid())
  wallet          String    @unique
  score           Int       @default(0)       // 0-100
  tier            String    @default("unverified")
  
  // SAID Engine breakdown (recomputed every 6h)
  identity        Float     @default(0)
  activity        Float     @default(0)
  economic        Float     @default(0)
  ecosystem       Float     @default(0)
  longevity       Float     @default(0)
  
  // FairScale enrichment (recomputed every 7d)
  fairscale       Float     @default(0)
  fairscaleRaw    Json?     // Raw FairScale API response
  fairscaleAt     DateTime? // When FairScale was last fetched
  
  badges          String[]  @default([])
  flags           String[]  @default([])
  sources         String[]  @default(["said"])
  
  computedAt      DateTime  @default(now())   // Last full computation
  lastQueriedAt   DateTime  @default(now())   // Last time someone requested this score
  
  agent           Agent     @relation(fields: [wallet], references: [wallet])
  
  @@index([score(sort: Desc)])
  @@index([tier])
  @@index([computedAt])
  @@index([lastQueriedAt])
}

model WalletLink {
  id          String   @id @default(cuid())
  
  // On-chain state (cache)
  pda         String   @unique
  agentPda    String   // Points to Agent.pda
  wallet      String   @unique
  
  // Metadata
  linkedAt    DateTime @default(now())
  lastSynced  DateTime @default(now())
  
  @@index([wallet])
  @@index([agentPda])
}

// ============================================================
// Delegated Signing Authority — Privy Agent Wallets
// ============================================================

model AgentWallet {
  id                String    @id @default(cuid())
  
  // Links to existing agent identity
  agentId           String
  agent             Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  
  // Wallet details
  publicKey         String    @unique   // Solana public key (from Privy)
  provider          String    @default("privy")  // privy, mock
  providerWalletId  String?   // Privy's internal wallet identifier
  
  // Wallet type
  walletType        String    @default("transaction")  // transaction, subscription
  isPrimary         Boolean   @default(false)  // Is this the agent's primary transaction wallet?
  
  // Status
  status            String    @default("active")  // active, suspended, revoked
  
  // Timestamps
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  // Metadata from Privy
  metadata          Json?
  
  // Relations
  transactions      TransactionRequest[]
  
  @@unique([agentId, walletType])  // One wallet per type per agent
  @@index([agentId])
  @@index([publicKey])
  @@index([status])
}

model TransactionRequest {
  id                String    @id @default(cuid())
  
  // Who requested it
  agentId           String
  agent             Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  walletId          String
  wallet            AgentWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  apiKeyId          String?
  apiKey            ApiKey?   @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  
  // Transaction details
  type              String    // transfer, swap, register, custom
  token             String    // USDC, SOL, etc.
  amount            Decimal   @db.Decimal(18, 6)
  recipient         String?   // Destination address
  programId         String?   // Solana program being called
  memo              String?
  
  // Raw transaction data
  serializedTx      String?   @db.Text  // Base64 serialized unsigned tx
  
  // Policy check
  policyPassed      Boolean?
  policyReason      String?   // Why approved/denied
  
  // Execution
  status            String    @default("pending")  // pending, approved, denied, signing, broadcast, confirmed, failed
  txHash            String?   // Solana transaction signature
  errorMessage      String?
  
  // Timestamps
  createdAt         DateTime  @default(now())
  signedAt          DateTime?
  broadcastAt       DateTime?
  confirmedAt       DateTime?
  
  @@index([agentId, createdAt(sort: Desc)])
  @@index([status])
  @@index([txHash])
}

model ApiKey {
  id                String    @id @default(cuid())
  
  // Who owns this key
  agentId           String
  agent             Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  
  // Key data (we store hash, never the raw key)
  keyHash           String    @unique
  keyPrefix         String    // First 12 chars for identification: said_ak_xxxx
  name              String?   // Human-readable label
  
  // Permissions
  scopes            String[]  @default(["wallet", "transaction"])
  
  // Rate limiting
  rateLimitPerHour  Int       @default(100)
  
  // Lifecycle
  createdAt         DateTime  @default(now())
  lastUsedAt        DateTime?
  expiresAt         DateTime?
  revokedAt         DateTime?
  
  // Who created this (user session token or admin)
  createdBy         String?
  
  // Relations
  transactions      TransactionRequest[]
  
  @@index([agentId])
  @@index([keyHash])
  @@index([keyPrefix])
}

model MonthlyUsage {
  id              String   @id @default(cuid())
  platformId      String
  month           String   // "2026-04"
  signatures      Int      @default(0)
  feesCollected   Float    @default(0)  // SOL
  agentsCreated   Int      @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([platformId, month])
  @@index([platformId])
}

model TransactionPolicy {
  id                    String    @id @default(cuid())
  
  // One policy per agent
  agentId               String    @unique
  agent                 Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  
  // Spending limits (in USDC equivalent)
  maxPerTransaction     Decimal   @default(10.00)  @db.Decimal(10, 2)
  maxPerDay             Decimal   @default(100.00) @db.Decimal(10, 2)
  maxPerMonth           Decimal   @default(1000.00) @db.Decimal(10, 2)
  
  // Token restrictions
  allowedTokens         String[]  @default(["USDC", "SOL"])
  
  // Program restrictions (Solana program IDs)
  allowedPrograms       String[]  @default([])
  
  // Approval thresholds
  requireApprovalAbove  Decimal   @default(50.00) @db.Decimal(10, 2)

  // Status
  status                String    @default("active")  // active, suspended

  // Timestamps
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([agentId])
}

// One per `submit_anchor` instruction on the SAID program. Each anchor
// commits a Merkle root over a contiguous range of off-chain receipts
// [startSeq, endSeq] for a given agent. Continuity is enforced on-chain:
// anchor #0 starts at seq 1, each subsequent anchor must start at the
// previous endSeq + 1. Indexed by an off-chain sync worker; never edited
// after insert.
model ReceiptAnchor {
  id          String   @id @default(cuid())
  pda         String   @unique                // ReceiptAnchor PDA on-chain
  agentPda    String                          // The agent identity PDA this anchor belongs to
  index       Int                             // Anchor sequence (0, 1, 2, ...)
  startSeq    BigInt                          // First receipt seq in this anchor
  endSeq      BigInt                          // Last receipt seq in this anchor
  root        String                          // Merkle root, hex-encoded (32 bytes)
  createdAt   DateTime                        // On-chain created_at (i64 unix ts)
  syncedAt    DateTime @default(now())        // When the indexer first saw it

  @@unique([agentPda, index])
  @@index([agentPda])
  @@index([createdAt])
}

// Rolling 30-day wallet activity snapshot per agent. Updated by a background
// job that pulls the agent's recent tx history from Alchemy and aggregates.
// One row per agent wallet; upserted on refresh. Purely a cache of signals
// we'll fold into the trust score — never the source of truth.
model AgentActivityStats {
  id                      String   @id @default(cuid())
  wallet                  String   @unique             // agent wallet
  windowDays              Int      @default(30)
  txCount                 Int      @default(0)         // total signed txs in window
  volumeSolLamports       BigInt   @default(0)         // gross SOL moved (in + out) in window, lamports
  uniqueCounterparties    Int      @default(0)
  activeDays              Int      @default(0)         // distinct days the wallet transacted
  oldestSeen              DateTime?                    // earliest tx in window we observed
  latestSeen              DateTime?                    // most recent tx
  computedAt              DateTime @default(now())
  source                  String   @default("alchemy") // which RPC fed this snapshot

  @@index([latestSeen])
}

// One row per SPL Token mint detected to have been initialized by an
// agent's wallet (i.e. agent.wallet == mint authority at init time).
// Enriched with DexScreener stats on a slower cadence. Used as a
// "tokens this agent launched" signal for the economic subscore.
model LaunchedToken {
  id                      String   @id @default(cuid())
  mint                    String   @unique             // SPL mint address
  agentWallet             String                       // the agent that launched it
  detectedAt              DateTime @default(now())
  firstSeenSlot           BigInt?                      // slot of the InitializeMint tx, if known

  // DexScreener-enriched fields (nullable until enriched, refreshed periodically)
  priceUsd                Float?
  marketCapUsd            Float?
  liquidityUsd            Float?
  volume24hUsd            Float?
  volumeLifetimeUsd       Float?
  dexId                   String?                      // 'pumpswap', 'raydium', 'meteora', etc.
  enrichedAt              DateTime?

  @@index([agentWallet])
  @@index([enrichedAt])
}

// One row per agent wallet, populated from x402scan's public tRPC.
// Captures the agent's participation in the x402 micropayment economy
// on BOTH sides: as a provider (selling endpoints, receiving USDC) and
// as a buyer (calling other agents' endpoints, paying USDC). Used by
// the v0.7 paid_service demonstrated-delivery signal — see
// reputation-engine-v7.ts detectDemonstratedDelivery.
//
// Sync cadence: 12-24h via scripts/sync-x402-activity.ts.
// Source-of-truth: https://www.x402scan.com/api/trpc/public.sellers.all.list
// and public.buyers.all.list.
model AgentX402Activity {
  wallet                  String   @id

  // Provider side (this wallet is paid for offering an x402 endpoint)
  providerTxCount         Int      @default(0)
  providerAmountAtomic    BigInt   @default(0) // raw USDC atomic units (6 decimals)
  providerUniqueBuyers    Int      @default(0)
  providerFacilitators    String[] @default([])
  providerLastSeenAt      DateTime?

  // Buyer side (this wallet pays other x402 endpoints)
  buyerTxCount            Int      @default(0)
  buyerAmountAtomic       BigInt   @default(0)
  buyerUniqueSellers      Int      @default(0)
  buyerFacilitators       String[] @default([])
  buyerLastSeenAt         DateTime?

  syncedAt                DateTime @default(now())

  @@index([providerUniqueBuyers])
  @@index([syncedAt])
}

// Per-wallet rollup of calls into the SAID program itself, broken down
// by Anchor instruction discriminator. Distinguishes "agent that
// actually uses SAID" (submits feedback, anchors receipts, etc.) from
// "agent that registered once and never came back."
//
// Populated by scripts/sync-said-engagement.ts which walks each
// verified wallet's tx history via Alchemy and filters for
// invocations of SAID_PROGRAM_ID (5dpw6KEQPn248pnkkaYyWfHwu2nfb3LUMbTucb6LaA8G).
//
// Used by reputation-engine-v7.ts computeSaidEngagementSubscore to
// produce a 0-10 sub-signal that gets meaningful weight in the
// composite — specifically to defeat the "registered + verified
// + profile filled = silver" trap that v0.7 exhibits without this
// signal.
model AgentSaidEngagement {
  wallet                  String   @id

  // ── Identity lifecycle (every verified agent has these → 0 score weight)
  registerCount           Int      @default(0) // register_agent
  getVerifiedCount        Int      @default(0) // get_verified
  registerAndStakeCount   Int      @default(0) // register_and_stake — economic commitment at registration
  sponsorRegisterCount    Int      @default(0) // sponsor_register — sponsored agents
  sponsorVerifyCount      Int      @default(0) // sponsor_verify
  updateAgentCount        Int      @default(0) // update_agent — metadata update

  // ── Active protocol participation (the meaningful signals)
  submitAnchorCount       Int      @default(0) // submit_anchor — proof-of-work commit (strongest signal)
  validateWorkCount       Int      @default(0) // validate_work — agent validating ANOTHER agent's work
  submitFeedbackCount     Int      @default(0) // submit_feedback — peer endorsement

  // ── Economic commitment
  stakeCount              Int      @default(0) // stake — initial stake (separate from register_and_stake)
  addStakeCount           Int      @default(0) // add_stake — top up stake post-registration
  unstakeLifecycleCount   Int      @default(0) // aggregate: request/complete/cancel/emergency unstake

  // ── Wallet linking
  linkWalletCount         Int      @default(0)
  unlinkWalletCount       Int      @default(0)
  transferAuthorityCount  Int      @default(0)

  // ── Negative signal
  slashAgentCount         Int      @default(0) // slash_agent — agent was slashed

  // ── Catch-all for any SAID program instruction we don't recognize
  otherSaidCount          Int      @default(0)
  totalSaidInstructions   Int      @default(0)

  firstSaidInteractionAt  DateTime?
  lastSaidInteractionAt   DateTime?
  scannedUpToSignature    String?
  syncedAt                DateTime @default(now())

  @@index([totalSaidInstructions])
  @@index([submitAnchorCount])
  @@index([syncedAt])
}
