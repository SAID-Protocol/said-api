{
  "name": "said-api",
  "version": "1.0.0",
  "description": "SAID Protocol API - Agent registry, reputation, and leaderboard",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npx prisma generate && tsc",
    "start": "npx prisma db push --accept-data-loss && node dist/index.js",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "v8:sync-x402-activity": "tsx scripts/sync-x402-activity.ts",
    "v8:sync-said-engagement": "tsx scripts/sync-said-engagement.ts",
    "v8:backfill": "tsx scripts/v8-backfill-events.ts",
    "v8:sync-x402-pertx": "tsx scripts/sync-x402-per-tx.ts",
    "v8:signals": "tsx scripts/v8-compute-signals.ts",
    "v8:posteriors": "tsx scripts/v8-compute-posteriors.ts",
    "v8:edges": "tsx scripts/v8-build-edges.ts",
    "v8:eigentrust": "tsx scripts/v8-compute-eigentrust.ts",
    "v8:recompute": "npm run v8:signals && npm run v8:posteriors && npm run v8:edges && npm run v8:eigentrust"
  },
  "keywords": [
    "said",
    "solana",
    "ai-agents",
    "reputation"
  ],
  "author": "SAID Protocol",
  "license": "MIT",
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@hono/node-server": "^1.14.1",
    "@metaplex-foundation/mpl-core": "^1.9.1",
    "@metaplex-foundation/mpl-token-metadata": "^3.4.0",
    "@metaplex-foundation/umi": "^1.5.1",
    "@metaplex-foundation/umi-bundle-defaults": "^1.5.1",
    "@payai/facilitator": "^2.2.4",
    "@prisma/client": "^6.5.0",
    "@privy-io/node": "^0.10.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.2",
    "@x402/evm": "^2.5.0",
    "@x402/fetch": "^2.5.0",
    "@x402/hono": "^2.5.0",
    "@x402/svm": "^2.5.0",
    "bs58": "^6.0.0",
    "bullmq": "^5.71.1",
    "dotenv": "^16.5.0",
    "ethers": "^6.16.0",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "hono": "^4.7.4",
    "ioredis": "^5.10.1",
    "prisma": "^6.5.0",
    "resend": "^6.9.1",
    "tweetnacl": "^1.0.3",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=20"
  }
}
